{
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": [
    "**/.env.*local",
    "tsconfig.json",
    "bun.lockb"
  ],
  "globalEnv": [
    "NEXTAUTH_SECRET",
    "NEXTAUTH_URL",
    "STRIPE_API_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "RESEND_API_KEY",
    "RESEND_FROM",
    "THIRDWEB_SECRET_KEY",
    "POSTGRES_URL",
    "POSTGRES_PRISMA_URL",
    "DATABASE_URL_UNPOOLED",
    "POSTGRES_URL_NON_POOLING",
    "POSTGRES_USER",
    "POSTGRES_HOST",
    "POSTGRES_PASSWORD",
    "POSTGRES_DATABASE",
    "POSTGRES_URL_NO_SSL",
    "DATABASE_URL",
    "PGHOST",
    "PGPASSWORD",
    "PGDATABASE",
    "PGUSER",
    "PGHOST_UNPOOLED",
    "SUPER_ADMIN_WALLET",
    "BLOB_READ_WRITE_TOKEN",
    "RESEND_FROM_EMAIL",
    "WHATSAPP_ACCESS_TOKEN",
    "WHATSAPP_PHONE_NUMBER_ID",
    "WHATSAPP_VERIFY_TOKEN",
    "RESEND_WEBHOOK_SECRET",
    "DISCORD_WEBHOOK_ALERTS",
    "DISCORD_WEBHOOK_APPLICATIONS",
    "PROTOCOL_ADMIN_PRIVATE_KEY",
    "DISCORD_WEBHOOK_WHATSAPP_LEADS",
    "CRON_SECRET",
    "DISCORD_SCHEDULING_WEBHOOK",
    "STRIPE_SECRET_KEY",
    "SEPOLIA_RPC_URL",
    "BASE_RPC_URL",
    "PANDORA_ORACLE_PRIVATE_KEY",
    "PANDORA_ORACLE_ADDRESS",
    "ROOT_TREASURY_ADDRESS",
    "GOV_ADDRESS_SEPOLIA",
    "JWT_PUBLIC_KEY",
    "DEPLOY_SECRET",
    "DEPLOY_SERVICE_URL",
    "PANDORA_CORE_KEY",
    "JWT_PRIVATE_KEY",
    "PANDORAS_FACTORY_ADDRESS",
    "RELAYER_PRIVATE_KEY",
    "OPENAI_API_KEY"
  ],
  "globalPassThroughEnv": [
    "NODE_ENV",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL",
    "VERCEL_GIT_COMMIT_REF",
    "VERCEL_GIT_COMMIT_SHA"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        ".contentlayer/**"
      ],
      "inputs": [
        "src/**",
        "package.json",
        "tsconfig.json",
        "next.config.*"
      ]
    },
    "build-packages": {
      "dependsOn": [],
      "inputs": [
        "packages/*/src/**",
        "packages/*/package.json",
        "packages/*/tsconfig.json"
      ],
      "outputs": [
        "packages/*/dist/**"
      ]
    },
    "build-apps": {
      "dependsOn": [
        "build-packages"
      ],
      "inputs": [
        "apps/*/src/**",
        "apps/*/package.json",
        "apps/*/tsconfig.json",
        "apps/*/next.config.*"
      ],
      "outputs": [
        "apps/*/.next/**"
      ]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "lint": {
      "dependsOn": [
        "^build-packages"
      ],
      "outputs": [
        "node_modules/.cache/.eslintcache"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^build-packages"
      ],
      "outputs": [
        "node_modules/.cache/tsbuildinfo.json"
      ]
    },
    "clean": {
      "cache": false
    }
  }
}