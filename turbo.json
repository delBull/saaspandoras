{
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": [
    "**/.env.*local",
    "tsconfig.json",
    "bun.lockb"
  ],
  "globalPassThroughEnv": [
    "NODE_ENV",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_URL",
    "VERCEL_GIT_COMMIT_REF",
    "VERCEL_GIT_COMMIT_SHA"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**"
      ],
      "inputs": [
        "src/**",
        "package.json",
        "tsconfig.json",
        "next.config.*"
      ]
    },
    "build-packages": {
      "dependsOn": [],
      "inputs": [
        "packages/*/src/**",
        "packages/*/package.json",
        "packages/*/tsconfig.json"
      ],
      "outputs": [
        "packages/*/dist/**"
      ]
    },
    "build-apps": {
      "dependsOn": [
        "build-packages"
      ],
      "inputs": [
        "apps/*/src/**",
        "apps/*/package.json",
        "apps/*/tsconfig.json",
        "apps/*/next.config.*"
      ],
      "outputs": [
        "apps/*/.next/**"
      ]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "lint": {
      "dependsOn": [
        "^build-packages"
      ],
      "outputs": [
        "node_modules/.cache/.eslintcache"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^build-packages"
      ],
      "outputs": [
        "node_modules/.cache/tsbuildinfo.json"
      ]
    },
    "clean": {
      "cache": false
    }
  }
}