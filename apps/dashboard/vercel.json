{
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "turbo run build --filter=@saasfly/dashboard...",
  "installCommand": "bun install --frozen-lockfile",
  "ignoreCommand": "exit 1",
  "crons": [
    {
      "path": "/api/cron/marketing",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/gas-check",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/reconcile-withdrawals",
      "schedule": "0 4 * * *"
    }
  ]
}