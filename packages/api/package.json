{
  "name": "@saasfly/api",
  "version": "0.1.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "import": "./dist/env.mjs",
      "require": "./dist/env.js"
    },
    "./edge": {
      "types": "./dist/edge.d.ts",
      "import": "./dist/edge.mjs",
      "require": "./dist/edge.js"
    },
    "./transformer": {
      "types": "./dist/transformer.d.ts",
      "import": "./dist/transformer.mjs",
      "require": "./dist/transformer.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "src/*"
      ]
    }
  },
  "scripts": {
    "clean": "rm -rf .turbo node_modules",
    "format": "prettier --check '**/*.{ts,mjs}' ",
    "typecheck": "tsc --noEmit",
    "build": "tsup src/index.ts src/env.mjs src/edge.ts src/transformer.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts src/env.mjs src/edge.ts src/transformer.ts --format esm,cjs --watch"
  },
  "dependencies": {
    "@saasfly/db": "workspace:*",
    "@trpc/client": "10.44.1",
    "@trpc/server": "10.44.1",
    "@t3-oss/env-nextjs": "0.8.0",
    "next-auth": "^4.24.11",
    "superjson": "2.2.1",
    "dinero.js": "2.0.0-alpha.14",
    "@dinero.js/currencies": "2.0.0-alpha.14",
    "zod": "^3.23.8",
    "zod-form-data": "2.0.2"
  },
  "devDependencies": {
    "@saasfly/eslint-config": "workspace:*",
    "@saasfly/prettier-config": "workspace:*",
    "@saasfly/typescript-config": "workspace:*",
    "eslint": "8.57.0",
    "prettier": "3.2.5",
    "tsup": "^8.5.1",
    "typescript": "5.4.5"
  },
  "eslintConfig": {
    "root": true,
    "extends": [
      "@saasfly/eslint-config/base"
    ]
  },
  "prettier": "@saasfly/prettier-config",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts"
}